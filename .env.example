NODE_ENV=development

# Puerto público de la API (host -> container 3000)
API_PUBLIC_PORT=3000

# Postgres (estos valores también los usa el servicio db)
DB_HOST=localhost
DB_PORT=3334
DB_NAME=HairSalon
DB_USER=luis
DB_PASSWORD=123456

# TypeORM (defaults no bloqueantes)
# - En production: por defecto synchronize=false y logging=false
# - En development: por defecto synchronize=true y logging=true
# TYPEORM_SYNCHRONIZE=true|false
# TYPEORM_LOGGING=true|false
# DB_SSL=true|false

# Compose: puerto público para Postgres (host -> container 5432)
DB_PUBLIC_PORT=3334

# Auth
JWT_SECRET=CHANGE_ME

# Cloudinary
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
CLOUDINARY_UPLOAD_FOLDER=products
CLOUDINARY_UPLOAD_PRESET=CHANGE_ME
